# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# GitHub Configuration for Feedback Integration
# To create a GitHub Personal Access Token:
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token (classic)"
# 3. Select the 'repo' scope (or 'public_repo' if your repo is public)
# 4. Copy the token and paste it here
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# GitHub Repository Details (change these to match your repo)
GITHUB_REPO_OWNER=grlibraries
GITHUB_REPO_NAME=babel-fish

# Firebase Configuration (optional - for Firebase Admin SDK)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
